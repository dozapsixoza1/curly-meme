# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:3000

# ── Security ─────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production!
JWT_SECRET=change-me-to-something-random-and-long-in-production

# ── Storage ───────────────────────────────────────────────────────────────────
BOTS_DIR=./bots_data
DB_PATH=./botnest.db

# ── Optional: Notification bot ───────────────────────────────────────────────
# If set, the platform sends you alerts when bots crash
# ADMIN_BOT_TOKEN=your_notification_bot_token
# ADMIN_CHAT_ID=your_chat_id
